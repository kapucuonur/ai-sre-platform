# SRE Platform Configurations
# (API Keys and Slack tokens can also be set securely via the Web Dashboard settings tab)
# Bu dosyayı GIT'E EKLEMEYİN — .env olarak kopyala ve doldur

# --- Gemini ---
GEMINI_API_KEY=

# --- Slack (opsiyonel) ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# --- Database ---
SRE_DB_DIR=./backend/data

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --forward-to localhost:8000/api/stripe/webhook
STRIPE_PRICE_PRO=price_...        # €49/month recurring price ID
STRIPE_PRICE_SCALE=price_...      # €149/month recurring price ID

# --- SMTP Mail (Zoner.fi) ---
SMTP_HOST=mail.zoner.fi
SMTP_PORT=587
SMTP_USERNAME=onur@trihonor.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=onur@trihonor.com
